#!/usr/bin/env bash
# SessionStart hook for om-claude-plugin
# Detects OM projects and injects available skills context

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Detect OM project — check working directory for OM indicators
is_om_project=false

if [ -f "package.json" ] && grep -q "@open-mercato/" package.json 2>/dev/null; then
  is_om_project=true
elif [ -f "AGENTS.md" ] && grep -q "Open Mercato" AGENTS.md 2>/dev/null; then
  is_om_project=true
elif [ -d ".ai" ]; then
  is_om_project=true
elif [ -d "app-spec" ]; then
  is_om_project=true
fi

# If not an OM project, exit silently
if [ "$is_om_project" = false ]; then
  echo '{}'
  exit 0
fi

# Detect legacy `.ai/skills/` directory in a consumer app — migration debt under
# current policy (plugin om-* is the single source of truth; consumer apps should
# not vendor a parallel `.ai/skills/` tree). We only flag NON-EMPTY trees: an
# empty leftover directory is harmless, but a directory containing SKILL.md files
# means the consumer is shadowing or duplicating plugin skills.
#
# Note: this is the inverse of pre-v1.17 behavior. The old `is_om_vanilla` block
# treated `.ai/skills/` presence as a positive routing signal and emitted a
# Hybrid Routing precedence note. Under the current policy that's wrong-direction
# — consumer apps should not have the directory at all, and AGENTS.md should
# route via `om-superpowers:om-*` skill invocations (see README "Consumer-app
# routing" for the canonical AGENTS.md pattern).
has_legacy_skills_dir=false
if [ -d ".ai/skills" ] && [ -n "$(find .ai/skills -maxdepth 3 -name SKILL.md -print -quit 2>/dev/null)" ]; then
  has_legacy_skills_dir=true
fi

# Detect AGENTS.md alignment state.
# Under current policy, the plugin ships a canonical AGENTS.md routing template
# at `${CLAUDE_PLUGIN_ROOT}/templates/AGENTS.md`. Each canonical carries a
# `<!-- om-superpowers:routing v=X.Y.Z synced=YYYY-MM-DD -->` marker at line 1.
# Consumer apps that successfully align inherit the marker via overwrite, which
# acts as a version pin. The hook reconciles consumer marker version against
# the plugin's current version on each session start:
#   - no marker → offer initial alignment
#   - marker version == plugin version → silent (up to date)
#   - marker version != plugin version → offer refresh (newer canonical available)
#
# Marker format frozen as of v1.17.1; the v1.17.0 format (`routing:v1.17.0`,
# no space, no version-attribute syntax) is treated as "no marker" and triggers
# re-alignment. Zero v1.17.0 markers existed in the wild at the time of the
# format change (alignment write never completed under v1.17.0), so there's no
# upgrade footprint to preserve.
canonical_agents_md="${PLUGIN_ROOT}/templates/AGENTS.md"
needs_agents_alignment=false
agents_alignment_reason=""
agents_alignment_kind=""  # "initial" or "refresh" — controls offer wording

plugin_version=""
if [ -f "${PLUGIN_ROOT}/.claude-plugin/plugin.json" ]; then
  plugin_version=$(grep -E '^[[:space:]]*"version"' "${PLUGIN_ROOT}/.claude-plugin/plugin.json" | head -1 | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')
fi

if [ -f "$canonical_agents_md" ] && [ -n "$plugin_version" ]; then
  if [ ! -f "AGENTS.md" ]; then
    needs_agents_alignment=true
    agents_alignment_kind="initial"
    agents_alignment_reason="no AGENTS.md exists in this consumer app"
  else
    # Parse marker — `v=X.Y.Z` is authoritative; `synced=...` is informational.
    # Wrap each grep in a `|| true` so a missing marker (grep exits 1) doesn't
    # trip `set -euo pipefail` and silently kill the whole hook.
    consumer_marker_version=$( { grep -oE 'om-superpowers:routing v=[0-9.]+' AGENTS.md 2>/dev/null || true; } | head -1 | sed 's/.*v=//')
    consumer_synced=$( { grep -oE 'synced=[0-9-]+' AGENTS.md 2>/dev/null || true; } | head -1 | sed 's/synced=//')

    if [ -z "$consumer_marker_version" ]; then
      needs_agents_alignment=true
      agents_alignment_kind="initial"
      agents_alignment_reason="AGENTS.md exists but lacks the plugin routing marker — likely scaffolded from an older create-mercato-app version, never aligned, or aligned under a pre-v1.17.1 marker format"
    elif [ "$consumer_marker_version" != "$plugin_version" ]; then
      needs_agents_alignment=true
      agents_alignment_kind="refresh"
      agents_alignment_reason="AGENTS.md aligned at plugin v${consumer_marker_version} (synced ${consumer_synced:-unknown}); current plugin is v${plugin_version} — newer canonical may have updated routing rows, Critical Rules, or Mandatory Module Mechanisms"
    fi
    # else: versions match → silent
  fi
fi

# Auto-detect entry point: scan for in-progress execution plans.
# A plan is "in progress" when it has at least one unchecked checkbox `- [ ]`.
# This handles both auto-create-pr's strict `Status: in-progress` format and
# the broader `## Progress` checklist convention used by manual plans.
most_recent_plan=""
in_progress_count=0
in_progress_list=""

if [ -d ".ai/runs" ]; then
  # ls -t sorts by mtime descending; first match with unchecked items wins
  while IFS= read -r f; do
    [ -e "$f" ] || continue
    if grep -q '^- \[ \]' "$f" 2>/dev/null; then
      in_progress_count=$((in_progress_count + 1))
      in_progress_list="${in_progress_list}- ${f}\n"
      if [ -z "$most_recent_plan" ]; then
        most_recent_plan="$f"
      fi
    fi
  done < <(ls -t .ai/runs/*.md 2>/dev/null)
fi

# Detect app-spec/ presence (ideation phase) and approved spec count
has_app_spec=false
if [ -d "app-spec" ]; then
  has_app_spec=true
fi

approved_specs_count=0
if [ -d ".ai/specs" ]; then
  # Wrap grep in a brace block with `|| true` to neutralize grep's exit-1
  # on no-match — otherwise `set -e` + `pipefail` exits the entire hook silently.
  approved_specs_count=$( { grep -l -i -E "Status:[[:space:]]*(approved|ready|implemented)" .ai/specs/*.md 2>/dev/null || true; } | wc -l | tr -d ' ')
fi

# Open-PR tracking-plan scan (canonical "in-flight work elsewhere" surface).
# The local .ai/runs/ scan above only sees plans on the current branch — plans on
# other branches that have an open PR (e.g., PR #4's tracking plan that lives on
# its own feature branch) escape that check. One `gh pr list` call surfaces them.
# Failure mode tolerated: if gh is unavailable, no auth, or network down, scan is
# skipped — hook still proceeds with local-only detection.
open_pr_plans=""
if command -v gh >/dev/null 2>&1; then
  open_pr_plans=$(gh pr list --state open --json number,headRefName,body --limit 30 2>/dev/null | python3 -c "
import sys, json, re
try:
    prs = json.load(sys.stdin)
    for pr in prs:
        body = pr.get('body','') or ''
        m = re.search(r'Tracking plan:\s*(\S+)', body)
        if m:
            print(f\"PR #{pr['number']} ({pr['headRefName']}): {m.group(1)}\")
except Exception:
    pass
" 2>/dev/null || true)
fi

# Build context message
read -r -d '' OM_CONTEXT << 'CTXEOF' || true
You are working in an Open Mercato project with OM Superpowers active.

## IMPORTANT: Session Start Behavior — Enforce the Process

When the session starts, briefly greet the user and announce that OM Superpowers are active. Then **detect where they are in the pipeline** and guide them to the correct next step. Do NOT present a menu of options — the process is sequential, not pick-any.

### The Pipeline (enforced order)

1. **om-product-manager (Mat)** → App Spec (brainstorm, workflows, user stories, platform mapping)
2. **om-cto (Piotr) Spec Orchestrator** → decomposes App Spec into functional specs + execution plan
3. **User reviews & approves specs**
4. **om-cto (Piotr) Implementation Orchestrator** → dispatches om-implement-spec per spec, checkpoints between specs
5. **om-implement-spec** → code + unit tests + integration tests + docs → auto-invokes om-code-review
6. **om-code-review** → CI/CD gate → merge

### How to detect where the user is

- **No App Spec exists for the feature** → Start at step 1 (om-product-manager)
- **App Spec exists but no functional specs** → Start at step 2 (om-cto Spec Orchestrator)
- **Functional specs exist but not approved** → Ask user to review & approve
- **Approved specs exist, not yet implemented** → Start at step 4 (om-cto Implementation Orchestrator)
- **Implementation in progress** → Resume at the current spec/phase
- **Implementation done, no code review** → Run om-code-review

### Standalone skills (can be used anytime, outside the pipeline)

These do NOT skip the pipeline — they are support tools. Only the names below are directly invocable via the Skill tool; specialist sub-references load via each skill's Task Router.
- **om-cto** — Advisory ("does OM already do X?", architecture questions, gap analysis), and via Task Router: spec-writing, toolkit-review, upstream-bug-triage, user-proxy
- **om-troubleshooter** — diagnose errors, 404s, migration issues, missing widgets; auto-routes to upstream-bug-triage when trace points into `node_modules/@open-mercato/*`
- **om-ux** — UI architecture review (also invoked during om-product-manager §3.5)
- **om-ds-guardian** — DS-compliant CRUD/data-table/form pages, DS health checks, backend-ui-design reference
- **om-integration-tests** — run existing test suites
- **om-code-review** — review a PR or diff (standalone)

### Rules

- If the user asks to "build X" or "add feature X", ALWAYS start at step 1 (om-product-manager). No shortcuts.
- If the user asks to "implement spec X", verify the spec is approved before proceeding.
- Never offer implementation as an option when specs don't exist yet.
- Tell the user where they are and what the next step is. Guide, don't ask.

### User Proxy

After greeting and pipeline guidance, check for the user proxy:

- If `app-spec/proxy-lessons.md` exists in the working directory → proxy is set up. Read the file for the proxy name and lesson count. Announce: "[Name] is active. [N] app lessons, [M] global lessons."
- If no proxy-lessons.md exists → introduce the proxy concept and ask the user to name them. Full onboarding flow: invoke `om-superpowers:om-cto` and load `references/user-proxy.md`.

The proxy is invoked by other skills before presenting questions to the user. You do not need to invoke it during session-start — it activates when skills call it.

## Available OM Skills

These are the 11 top-level skills you can invoke directly via the Skill tool (`om-superpowers:om-<name>`). Specialist sub-references (module-scaffold, data-model-design, system-extension, eject, integration-builder, spec-writing, toolkit-review, user-proxy, upstream-bug-triage, backend-ui-design, pre-impl-analysis) are NOT directly invocable — they load on demand via each skill's Task Router.

**Spec & Design:**
- om-product-manager: Product owner workflow — business context, workflows, user stories, platform mapping
- om-cto: CTO challenge — gap analysis, "does OM already do X?", atomic commit estimation. Task Router: spec-orchestrator, impl-orchestrator, pre-impl-analysis, toolkit-audit, upstream-bug-triage, spec-writing, user-proxy, advisory.
- om-ux: UI architecture review — navigation, task completion, cognitive load

**Implementation:**
- om-implement-spec: Multi-phase spec implementation with coordinated subagents. Task Router: module-scaffold, data-model-design, system-extension (and eject sub-ref), integration-builder, code-review-compliance.
- om-ds-guardian: DS enforcement + backend admin page builder (CRUD/data-table/form pages). Task Router: backend-ui-design, page-templates, component-guide, specialized-inputs, token-mapping.

**Testing & Quality:**
- om-code-review: CI/CD verification gate + full OM checklist (20+ sections)
- om-integration-tests: Playwright integration test creation and execution
- om-troubleshooter: Diagnose and fix common OM issues (errors, 404s, migrations, widgets). Auto-routes upstream-bug findings to om-cto/upstream-bug-triage.

**Automation (PR lifecycle):**
- om-auto-create-pr: Execute an autonomous agent task end-to-end and deliver as a GitHub PR against `develop`
- om-auto-continue-pr: Resume an in-progress PR started by auto-create-pr
- om-auto-review-pr: Review or re-review a GitHub PR by number in an isolated worktree

## Rules

- ALWAYS prefer om-* skills over generic equivalents when working on OM code.
- Once a skill workflow is started, follow it to completion — do not break out or skip steps.
- Do not wait for the user to say "use superpowers" or "follow om skills" — they are always on.
CTXEOF

# Legacy `.ai/skills/` warning — only when a non-empty directory is found in
# the consumer app. Under current policy, plugin om-* is the single source of
# truth; a consumer app vendoring its own SKILL.md files is migration debt that
# the agent must NOT prefer over the plugin equivalents.
if [ "$has_legacy_skills_dir" = true ]; then
  read -r -d '' LEGACY_SKILLS_WARNING << 'LEGEOF' || true


## Legacy `.ai/skills/` Directory Detected — DO NOT Use It as Authoritative

This consumer app contains a non-empty `.ai/skills/` directory with SKILL.md files. Under current om-superpowers policy, that directory is **migration debt** — plugin `om-*` skills are the single source of truth for OM workflows.

### What to do

- **Do NOT** `Read` files under `.ai/skills/<name>/SKILL.md` and follow them as authoritative instructions. Their content may shadow, duplicate, or contradict the plugin equivalent.
- **Do** invoke the plugin namespace via the Skill tool. The Task → Plugin Skill map is:
  - `troubleshooter` → `om-superpowers:om-troubleshooter`
  - `code-review` → `om-superpowers:om-code-review`
  - `implement-spec`, `module-scaffold`, `data-model-design`, `system-extension`, `eject-and-customize`, `integration-builder` → `om-superpowers:om-implement-spec` (its Task Router loads the right reference)
  - `backend-ui-design` → `om-superpowers:om-ds-guardian`
  - `spec-writing`, `toolkit-review`, `user-proxy` → `om-superpowers:om-cto` (its Task Router loads the right reference)
  - `integration-tests` → `om-superpowers:om-integration-tests`
- **If older docs (specs, plans, runs/, PR comments) reference `.ai/skills/<name>/SKILL.md`**, treat the reference as a relic of the v1.x migration and invoke the plugin equivalent above instead of attempting to `Read` the missing/stale file.

### Heads-up to surface to the user (once per session is enough)

Mention to the user that `.ai/skills/` is leftover migration debt and can be removed — the plugin handles all OM skill routing now. Do not delete the directory automatically; let the user decide.
LEGEOF

  OM_CONTEXT="${OM_CONTEXT}${LEGACY_SKILLS_WARNING}"
fi

# AGENTS.md alignment offer — confirm-then-overwrite flow. Triggers when the
# consumer's AGENTS.md is missing, lacks the plugin routing marker, or carries
# a marker for an older plugin version. Two kinds of offer, both with the same
# Yes/No/Show-diff option set but different prompt wording so the user knows
# whether it's a first-time alignment or a refresh.
#
# IMPORTANT — this instruction block is intentionally explicit about
# atomic execution because v1.17.0 sessions hit a partial-execution bug:
# agent created AGENTS.md.bak via `cp` but never proceeded to Read+Write,
# leaving the consumer "half-aligned" (backup exists, original unchanged, no
# marker present). The v1.17.1 instructions below make the Yes-flow atomic
# and require a post-Write marker verification.
if [ "$needs_agents_alignment" = true ]; then
  if [ "$agents_alignment_kind" = "refresh" ]; then
    OFFER_HEADER="AGENTS.md Refresh Available — Plugin Version Drifted"
    QUESTION_TEXT="Refresh this app's \`AGENTS.md\` to plugin v${plugin_version}'s canonical? Existing \`AGENTS.md\` will be backed up to \`AGENTS.md.bak\` (overwriting any prior backup). Differences may include updated Critical Rules, new Mandatory Module Mechanisms rows, or revised plugin-namespace routing — review the diff (Show diff first) if unsure."
  else
    OFFER_HEADER="AGENTS.md Alignment Available — Confirm With User Before Overwriting"
    QUESTION_TEXT="Align this app's \`AGENTS.md\` with the om-superpowers canonical routing template (plugin v${plugin_version})? Existing \`AGENTS.md\` (if any) will be backed up to \`AGENTS.md.bak\`. The canonical contains plugin-namespace routing but may not include project-specific notes from your existing file — you may want to copy those back manually afterwards."
  fi

  AGENTS_ALIGNMENT_OFFER=$(printf '\n\n## %s\n\nThe canonical om-superpowers routing template lives at `%s`. The current consumer-app AGENTS.md state: **%s**.\n\n### What to do BEFORE responding to the user'"'"'s actual prompt\n\nInvoke `AskUserQuestion` with a single question — phrase it close to this:\n\n> "%s"\n\nOptions to present:\n- **Yes, %s now** — perform the overwrite (see Yes-flow below)\n- **No, skip this session** — do nothing; do not re-prompt this session\n- **Show diff first** — display the diff, then re-ask (see Show-diff flow below)\n\n### Yes-flow — execute as ONE response (do NOT interleave with other work)\n\nThese three tool calls happen back-to-back in a single agent response. Do not pause for the user, do not start work on their original prompt, until all four steps complete (or step 4 detects a problem):\n\n1. **Bash**: `cp AGENTS.md AGENTS.md.bak` (only if `AGENTS.md` currently exists; overwriting any prior `.bak`)\n2. **Read** `%s` (the canonical)\n3. **Write** the entire canonical content (verbatim, including the marker line) to `AGENTS.md`\n4. **Verification — REQUIRED**: `Bash` `head -1 AGENTS.md` and confirm it contains `om-superpowers:routing v=%s`. If the marker is NOT on line 1, the Write failed — investigate (path, permissions, content truncation) and retry before moving on.\n\nOnly after step 4 confirms the marker is present:\n5. Tell the user: "Aligned to plugin v%s. Backup at `AGENTS.md.bak`. The canonical contains plugin-namespace routing; review the .bak for project-specific notes (env vars, integration setup, module-specific guidance) and merge them back into `AGENTS.md` manually."\n6. Continue with the user'"'"'s original prompt.\n\n### Show-diff flow — DO NOT cp anything yet\n\nIf the user picks "Show diff first", DO NOT create `AGENTS.md.bak` and DO NOT modify `AGENTS.md`. Instead:\n\n1. `Read` the current `AGENTS.md`\n2. `Read` the canonical at `%s`\n3. Present a focused diff to the user — summarize the substantive differences (added routing rows, removed Critical Rules, marker version delta). Do NOT dump the full file contents.\n4. Re-invoke `AskUserQuestion` with only `Yes, %s now` / `No, skip this session` options.\n5. If `Yes` → run the Yes-flow above. If `No` → skip this session.\n\n### No-flow\n\nDo not offer again this session. Move on to the user'"'"'s actual prompt.\n\n### Constraints — read carefully\n\n- Do NOT create `AGENTS.md.bak` until the user has explicitly confirmed `Yes`. Premature `.bak` creation is the v1.17.0 bug — the cp ran but the subsequent Write did not, leaving the consumer half-aligned.\n- Do NOT overwrite `AGENTS.md` without explicit `Yes` confirmation. The canonical does not preserve project-specific content; silent overwrite would destroy it.\n- Do NOT add the user'"'"'s project-specific content to the canonical automatically. The plugin'"'"'s template is intentionally generic; project-specific notes are the consumer'"'"'s responsibility.\n- Do NOT offer this if the user has already declined in the current session (track via your own conversation memory).\n' "$OFFER_HEADER" "$canonical_agents_md" "$agents_alignment_reason" "$QUESTION_TEXT" "$agents_alignment_kind" "$canonical_agents_md" "$plugin_version" "$plugin_version" "$canonical_agents_md" "$agents_alignment_kind")

  OM_CONTEXT="${OM_CONTEXT}${AGENTS_ALIGNMENT_OFFER}"
fi

# Auto-detected entry point recommendation. Fires when project state is detectable
# from filesystem signal — even if user prompt is vague ("continue", "let's go",
# "finish this"). The recommendation is a specific command, not prose advice.
ENTRY_POINT=""

if [ -n "$most_recent_plan" ]; then
  plan_basename=$(basename "$most_recent_plan")
  unchecked=$(grep -c '^- \[ \]' "$most_recent_plan" 2>/dev/null || echo 0)
  total=$(grep -cE '^- \[[ x]\]' "$most_recent_plan" 2>/dev/null || echo 0)

  ENTRY_POINT_DETAIL=$(printf '\n\n## Auto-Detected Entry Point — IN-PROGRESS RUN\n\nA plan with **%s unchecked steps** (of %s total) was found:\n\n```\n%s\n```\n\n**When the user prompt is vague** ("continue", "finish this", "let'"'"'s go", "what'"'"'s next", "resume"), do NOT default to ad-hoc Bash commits. Instead:\n\n1. Find the matching open PR — `gh pr list --search "Tracking plan: %s" --state open --json number --jq ".[0].number"`\n2. If a PR is found → invoke the `om-auto-continue-pr` Skill with that PR number. The auto-continue-pr workflow runs the tests-with-code gate at commit time (v1.10.0+).\n3. If no PR is found but the plan has a clear branch in `git branch --list "fix/*" "feat/*"` → invoke `om-implement-spec` against the plan'"'"'s Source spec line.\n4. If neither → ask the user how to proceed; do not start ad-hoc work.\n\n**Why this matters.** Per-atomic-commit gates (currently: tests-with-code; future: DS, e2e, code-review when baseline justifies) live INSIDE the `om-auto-create-pr` / `om-auto-continue-pr` SKILL.md content. They only fire when those skills are invoked. Ad-hoc `git commit` calls bypass the gate. The recommendation above ensures the agent enters through a skill, where gates are present.\n' "$unchecked" "$total" "$most_recent_plan" "$plan_basename")
  ENTRY_POINT="${ENTRY_POINT}${ENTRY_POINT_DETAIL}"

  if [ "$in_progress_count" -gt 1 ]; then
    ENTRY_POINT="${ENTRY_POINT}$(printf '\n### Other in-progress plans found (%s total)\n\n%b' "$in_progress_count" "$in_progress_list")"
  fi
elif [ "$approved_specs_count" -gt 0 ]; then
  ENTRY_POINT=$(printf '\n\n## Auto-Detected Entry Point — APPROVED SPECS\n\n%s spec(s) marked as approved/ready in `.ai/specs/`. No execution plan in `.ai/runs/` yet.\n\n**Action when user prompts to build / implement:** invoke the `om-cto` Skill in Implementation Orchestrator mode — it dispatches `om-implement-spec` per approved spec with checkpoints between specs.\n\nDo NOT start coding without going through `om-cto` first; specs need to be picked in the right order and the orchestrator handles that.\n' "$approved_specs_count")
elif [ "$has_app_spec" = true ]; then
  ENTRY_POINT=$(printf '\n\n## Auto-Detected Entry Point — APP SPEC PHASE\n\nAn `app-spec/` directory exists. No functional specs in `.ai/specs/` and no in-progress runs.\n\n**Action when user prompts to build / continue:**\n- If `app-spec/` contains a Cagan App Spec (workflows, user stories, platform mapping) → invoke `om-cto` Spec Orchestrator to decompose into functional specs.\n- If `app-spec/` is empty or only stubs → invoke `om-product-manager` (Cagan/Mat) to author the App Spec.\n')
fi

OM_CONTEXT="${OM_CONTEXT}${ENTRY_POINT}"

# In-flight work elsewhere: open PRs with their own tracking plans.
# This is additive to ENTRY_POINT — even when the local working dir has no
# in-progress plan, OTHER branches may. v1.11.3 adds this scan after the
# patryk-standalone session re-implemented WIC ingestion as a "T4" parallel
# branch despite an open PR #4 already covering the same Spec.
if [ -n "$open_pr_plans" ]; then
  OPEN_PR_BLOCK=$(printf '\n\n## In-Flight Work Detected Elsewhere (open PRs with tracking plans)\n\nOther branches have execution plans backed by OPEN PRs. The local `.ai/runs/` directory only shows plans on the current branch — these are the canonical in-flight items across the repo:\n\n```\n%s\n```\n\n### Hard rule before starting any new work\n\nIf the incoming task overlaps with any PR above (same Spec number, same module, same feature area):\n\n1. **STOP.** Do NOT create a new branch + new plan + new PR for the same work.\n2. Run `gh pr view <PR#>` to confirm overlap.\n3. If overlapping → invoke `om-auto-continue-pr <PR#>` to resume on the existing branch.\n4. If genuinely parallel work (different Spec, same module is fine) → acknowledge the overlap explicitly to the user before proceeding.\n\nIf you cannot tell whether your task overlaps with an open PR'"'"'s plan, **ask the user** rather than guess. The cost of a 30-second clarification is far lower than 30+ minutes of duplicate work.\n' "$open_pr_plans")
  OM_CONTEXT="${OM_CONTEXT}${OPEN_PR_BLOCK}"
fi

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

escaped_context=$(escape_for_json "$OM_CONTEXT")

# Output for Claude Code or Cursor
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
fi

exit 0
